/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Biocentric/gvanno-nf - Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // input/output
    input               = null
    outdir              = './results'
    publish_dir_mode    = 'copy'
    email               = null

    // reference data
    genome              = 'GRCh38'                    // GRCh37 | GRCh38
    refdata_dir         = null                        // path to staged bundle
    refdata_version     = '20231224'                  // pinned to upstream gvanno 1.7.0
    refdata_mode        = 'prestaged'                 // prestaged | download
    refdata_url_base    = [
        'http://insilico.hpc.uio.no/pcgr/gvanno',
        'https://github.com/Biocentric/gvanno-nf/releases/download/refdata-20231224'
    ]

    // VEP tunables (mirror of gvanno CLI flags)
    vep_n_forks         = 4
    vep_buffer_size     = 500
    vep_pick_order      = 'mane_select,mane_plus_clinical,canonical,appris,tsl,biotype,ccds,rank,length'
    vep_regulatory      = false
    vep_gencode_basic   = false
    vep_lof_prediction  = false
    vep_no_intergenic   = false
    vep_coding_only     = false

    // vcfanno
    vcfanno_n_processes = 4

    // post-processing
    oncogenicity_annotation = false                   // requires vep_lof_prediction
    flavour                 = 'gvanno'                // gvanno | pcgr (PCGR is future-only stub)
    keep_intermediates      = false

    // scatter/gather
    scatter_by          = 'none'                      // none | chromosome

    // container override (advanced — leave alone unless splitting per-tool)
    gvanno_container    = 'sigven/gvanno:1.7.0'

    // boilerplate
    help                = false
    version             = false
    validate_params     = true
    monochrome_logs     = false
    show_hidden_params  = false
}

// Genome map (single source of truth for assembly-specific values)
includeConfig 'conf/genomes.config'
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    debug          { process.beforeScript = 'echo $HOSTNAME' }

    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        podman.enabled         = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }
    apptainer {
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        docker.enabled         = false
    }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }
    test           { includeConfig 'conf/test.config'      }
    test_full      { includeConfig 'conf/test_full.config' }
}

// nf-core convention: capture trace/timeline/report
timeline { enabled = true; file = "${params.outdir}/pipeline_info/execution_timeline.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/execution_report.html"   }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/execution_trace.txt"     }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/pipeline_dag.html"       }

manifest {
    name            = 'Biocentric/gvanno-nf'
    author          = 'Biocentric'
    homePage        = 'https://github.com/Biocentric/gvanno-nf'
    description     = 'Nextflow / nf-core style refactor of sigven/gvanno (germline DNA variant annotation)'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.10.0'
    version         = '0.1.0dev'
    doi             = ''
}
