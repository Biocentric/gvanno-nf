{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "https://raw.githubusercontent.com/Biocentric/gvanno-nf/main/assets/samplesheet_schema.json",
    "title": "gvanno-nf samplesheet schema",
    "description": "One row per VCF to annotate.",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._-]+$",
                "errorMessage": "Sample name must contain only A-Z, a-z, 0-9, dot, underscore, dash."
            },
            "vcf": {
                "type": "string",
                "pattern": "^\\S+\\.vcf(\\.gz)?$",
                "format": "file-path"
            },
            "vcf_index": {
                "type": "string",
                "pattern": "^\\S+\\.tbi$",
                "format": "file-path"
            }
        },
        "required": ["sample", "vcf"]
    }
}
