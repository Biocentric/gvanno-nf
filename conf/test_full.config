/*
 * Full test profile: full gvanno bundle, real example VCF.
 * Run by hand or in a weekly CI job; not for PR validation.
 */

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Full annotation against the real gvanno bundle'

    input           = "${projectDir}/assets/test_full_samplesheet.csv"
    genome          = 'GRCh37'
    vep_lof_prediction       = true
    oncogenicity_annotation  = true
}
