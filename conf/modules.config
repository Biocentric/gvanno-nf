/*
 * Per-process configuration: publishDir, ext.args, ext.prefix.
 * Keep all "magic CLI strings" here so process bodies stay generic.
 */

process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: 'VALIDATE_VCF' {
        publishDir = [
            path:    { "${params.outdir}/annotation/${meta.id}/logs" },
            mode:    params.publish_dir_mode,
            pattern: '*.log',
            enabled: params.keep_intermediates
        ]
    }

    withName: 'VEP' {
        ext.prefix = { "${meta.id}.${shard}.vep" }
        publishDir = [
            path:    { "${params.outdir}/annotation/${meta.id}/logs" },
            mode:    params.publish_dir_mode,
            pattern: '*.log'
        ]
    }

    withName: 'VCFANNO' {
        ext.prefix = { "${meta.id}.${shard}.vep.vcfanno" }
        publishDir = [
            path:    { "${params.outdir}/annotation/${meta.id}/logs" },
            mode:    params.publish_dir_mode,
            pattern: '*.log'
        ]
    }

    withName: 'SUMMARISE' {
        ext.prefix = { "${meta.id}.${shard}.vep.vcfanno.summarised" }
    }

    withName: 'BCFTOOLS_CONCAT' {
        ext.prefix = { "${meta.id}.gvanno.${params.genomes[params.genome].vep_assembly}" }
        publishDir = [
            path:    { "${params.outdir}/annotation/${meta.id}" },
            mode:    params.publish_dir_mode,
            pattern: '*.{vcf.gz,vcf.gz.tbi}'
        ]
    }

    withName: 'VCF2TSV' {
        ext.prefix = { "${meta.id}.gvanno.${params.genomes[params.genome].vep_assembly}" }
    }

    withName: 'FINALIZE_TSV' {
        ext.prefix = { "${meta.id}.gvanno.${params.genomes[params.genome].vep_assembly}" }
        publishDir = [
            path:    { "${params.outdir}/annotation/${meta.id}" },
            mode:    params.publish_dir_mode,
            pattern: '*.tsv.gz'
        ]
    }

    withName: 'BUNDLE_FETCH|BUNDLE_VERIFY' {
        publishDir = [
            path:    { "${params.outdir}/prepare_references" },
            mode:    params.publish_dir_mode,
            pattern: 'manifest*.tsv'
        ]
    }

    withName: 'MULTIQC' {
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode
        ]
    }
}
