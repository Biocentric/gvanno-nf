/*
 * Default resources per process label.
 * Tuned for a single germline VCF (~5-50M variants) on a workstation.
 */

process {
    cpus   = { params.check_max( 1 * task.attempt, 'cpus'   ) }
    memory = { params.check_max( 4.GB * task.attempt, 'memory' ) }
    time   = { params.check_max( 4.h  * task.attempt, 'time'   ) }

    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    withLabel: process_low {
        cpus   = { params.check_max( 2 * task.attempt, 'cpus'   ) }
        memory = { params.check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { params.check_max( 2.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_medium {
        cpus   = { params.check_max( 4 * task.attempt, 'cpus'   ) }
        memory = { params.check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { params.check_max( 6.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_high {
        cpus   = { params.check_max( 8  * task.attempt, 'cpus'   ) }
        memory = { params.check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { params.check_max( 12.h * task.attempt, 'time'   ) }
    }
    withLabel: process_vep {
        // VEP wants many forks but is memory-hungry per fork because of the cache
        cpus   = { params.check_max( params.vep_n_forks * task.attempt, 'cpus' ) }
        memory = { params.check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { params.check_max( 24.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_long {
        time = { params.check_max( 48.h * task.attempt, 'time' ) }
    }

    withName: 'BUNDLE_FETCH' {
        // single-thread, network-bound; long timeout because the bundle is ~20 GB
        cpus   = 2
        memory = 4.GB
        time   = 24.h
    }
}

// Cap defaults — overridden per-profile (e.g. test.config drops these)
params {
    max_memory = '128.GB'
    max_cpus   = 32
    max_time   = '240.h'
}

// check_max helper — defined as a closure on params so it can be referenced from process scopes.
// (Nextflow 26 disallows `def` functions at config top-level.)
params.check_max = { obj, type ->
    if (type == 'memory') {
        try {
            return obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1 ? params.max_memory as nextflow.util.MemoryUnit : obj
        } catch (Exception ignored) { return obj }
    } else if (type == 'time') {
        try {
            return obj.compareTo(params.max_time as nextflow.util.Duration) == 1 ? params.max_time as nextflow.util.Duration : obj
        } catch (Exception ignored) { return obj }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj as int, params.max_cpus as int)
        } catch (Exception ignored) { return obj }
    }
    return obj
}
