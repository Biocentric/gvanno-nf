/*
 * Lightweight CI profile.
 * Uses a chr22-only reference subset and the upstream gvanno example VCF.
 * Expects you to have pre-staged the test bundle under params.refdata_dir.
 */

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test on chr22 fixture'

    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '2.h'

    input           = "${projectDir}/assets/test_samplesheet.csv"
    genome          = 'GRCh37'
    refdata_dir     = params.refdata_dir ?: '/tmp/gvanno-nf-test-refs'
    refdata_mode    = 'prestaged'

    vep_n_forks     = 2
    vep_buffer_size = 100
    scatter_by      = 'none'
}
